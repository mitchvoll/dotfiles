start_nvim() {
    BASE_SOCKET="/tmp/nvim"

    if [ -e "$BASE_SOCKET" ]; then
        # Generate a unique socket using a timestamp
        SOCKET="$BASE_SOCKET-$(date +%s)"
    else
        SOCKET="$BASE_SOCKET"
    fi

    # Save the socket path to a temporary file
    echo "$SOCKET" > /tmp/nvim_socket_path

    # Start Neovim with the unique socket
    nvim --listen "$SOCKET"
}
alias aivim='start_nvim'
